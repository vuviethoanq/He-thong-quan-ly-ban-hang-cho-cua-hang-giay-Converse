@model IEnumerable<Converse_NMCNPM.Models.ChiTietSP>

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var sanPham = ViewBag.SanPham as Converse_NMCNPM.Models.SanPham;
}

<h1>Chi tiết sản phẩm</h1>

<div class="card p-4 mt-3">
    <h4 class="mb-3">
        Sản phẩm:
        @(sanPham != null ? sanPham.TenSP : "")
    </h4>

    <table class="table table-bordered table-hover align-middle">
        <thead>
            <tr>
                <th>Hình ảnh</th>
                <th>Mã CTSP</th>
                <th>Màu sắc</th>
                <th>Size</th>
                <th>Tồn kho</th>
                <th>Discount</th>
                <th>Giá</th>
                <th>Edit</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var giaSauGiam = (sanPham != null)
                ? sanPham.GiaSP * (100 - item.Discount) / 100
                : 0;

                var imageUrl = !string.IsNullOrEmpty(item.HinhAnh)
                ? Url.Content("~/images/products/" + item.HinhAnh)
                : Url.Content("~/images/products/no-image.png");

                <tr>
                    <td style="width:120px;">
                        <img src="@imageUrl"
                             alt="@item.MaCTSP"
                             style="width:80px; height:80px; object-fit:cover; border-radius:8px; border:1px solid #ddd;" />
                    </td>
                    <td>@item.MaCTSP</td>
                    <td>@item.MauSP</td>
                    <td>@item.SizeSP</td>
                    <td>@item.SoLuongTon</td>
                    <td>@item.Discount %</td>
                    <td>@giaSauGiam.ToString("N0") VNĐ</td>
                    <td>
                        <a asp-controller="ChiTietSPs"
                           asp-action="Edit"
                           asp-route-id="@item.MaCTSP"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>