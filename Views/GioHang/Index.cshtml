@model Converse_NMCNPM.Models.GioHangViewModel

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h1>Giỏ hàng</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card p-4 mt-3">
    @if (Model.Items.Any())
    {
        <table class="table table-bordered align-middle">
            <thead>
                <tr>
                    <th>Hình ảnh</th>
                    <th>Sản phẩm</th>
                    <th>Màu</th>
                    <th>Size</th>
                    <th>Số lượng</th>
                    <th>Đơn giá</th>
                    <th>Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var imageUrl = !string.IsNullOrEmpty(item.HinhAnh)
                    ? Url.Content("~/images/products/" + item.HinhAnh)
                    : Url.Content("~/images/products/no-image.png");

                    <tr>
                        <td>
                            <img src="@imageUrl" style="width:70px;height:70px;object-fit:cover;border-radius:8px;" />
                        </td>
                        <td>@item.TenSP</td>
                        <td>@item.MauSP</td>
                        <td>@item.SizeSP</td>
                        <td>@item.SoLuong</td>
                        <td>@item.DonGia.ToString("N0")đ</td>
                        <td>@item.ThanhTien.ToString("N0")đ</td>
                        <td>
                            <form asp-action="Xoa" method="post">
                                <input type="hidden" name="maCTSP" value="@item.MaCTSP" />
                                <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3 mb-4">
            <h4>Tổng tiền: @Model.TongTien.ToString("N0")đ</h4>
        </div>

        <h4>Thông tin khách hàng</h4>

        <form id="checkoutForm" asp-action="ThanhToan" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="TenKH" class="form-label">Tên khách hàng</label>
                <input asp-for="TenKH" class="form-control" />
                <span asp-validation-for="TenKH" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SDT" class="form-label">Số điện thoại</label>
                <input asp-for="SDT" class="form-control" />
                <span asp-validation-for="SDT" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DiaChi" class="form-label">Địa chỉ</label>
                <input asp-for="DiaChi" class="form-control" />
                <span asp-validation-for="DiaChi" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="PhuongThucThanhToan" class="form-label">Phương thức thanh toán</label>
                <select asp-for="PhuongThucThanhToan" class="form-select" id="paymentMethod">
                    <option value="TienMat">Tiền mặt</option>
                    <option value="ChuyenKhoan">Chuyển khoản</option>
                </select>
                <span asp-validation-for="PhuongThucThanhToan" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary" id="btnOpenPaymentConfirm">Thanh toán</button>
            </div>

            <div id="cashConfirmBox" class="card p-3 mt-4" style="display:none;">
                <h5>Xác nhận thanh toán tiền mặt</h5>
                <p>Bạn xác nhận đã nhận tiền mặt từ khách?</p>
                <button type="submit" class="btn btn-success" id="btnConfirmCash">Xác nhận thanh toán</button>
            </div>

            <div id="bankTransferBox" class="card p-3 mt-4" style="display:none;">
                <h5>Thanh toán chuyển khoản</h5>
                <p>Quét mã QR để thanh toán:</p>

                <img src="~/images/qr-payment.png"
                     alt="QR thanh toán"
                     style="max-width:260px; border:1px solid #ddd; border-radius:10px; padding:8px;" />

                <p class="mt-3 mb-2">
                    Nội dung chuyển khoản: <strong>THANHTOAN @Model.TongTien.ToString("N0")</strong>
                </p>

                <button type="submit" class="btn btn-success" id="btnConfirmTransfer">
                    Xác nhận đã chuyển khoản
                </button>
            </div>
        </form>
    }
    else
    {
        <div class="text-center">
            <p>Giỏ hàng đang trống.</p>
            <a asp-controller="SanPhams" asp-action="Index" class="btn btn-primary">Tiếp tục mua hàng</a>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const paymentMethod = document.getElementById("paymentMethod");
            const btnOpenPaymentConfirm = document.getElementById("btnOpenPaymentConfirm");
            const cashConfirmBox = document.getElementById("cashConfirmBox");
            const bankTransferBox = document.getElementById("bankTransferBox");

            function hideAllConfirmBoxes() {
                cashConfirmBox.style.display = "none";
                bankTransferBox.style.display = "none";
            }

            hideAllConfirmBoxes();

            btnOpenPaymentConfirm.addEventListener("click", function () {
                hideAllConfirmBoxes();

                if (paymentMethod.value === "TienMat") {
                    cashConfirmBox.style.display = "block";
                } else if (paymentMethod.value === "ChuyenKhoan") {
                    bankTransferBox.style.display = "block";
                }
            });
        });
    </script>
}