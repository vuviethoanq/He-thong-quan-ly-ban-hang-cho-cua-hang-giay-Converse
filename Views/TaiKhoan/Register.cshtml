@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng ký</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background:linear-gradient(135deg,#111,#444);height:100vh;display:flex;justify-content:center;align-items:center;">

    <div class="card p-4 shadow" style="width:430px;border-radius:20px;">
        <h2 class="text-center mb-4">Đăng ký</h2>

        <form method="post">
            <input name="MaNV" class="form-control mb-3" placeholder="Mã nhân viên" required />
            <input name="Username" class="form-control mb-3" placeholder="Tài khoản" required />
            <input type="password" name="Password" class="form-control mb-3" placeholder="Mật khẩu" required />

            <select name="Role" class="form-select mb-3">
                <option value="Staff">Staff</option>
                <option value="Admin">Admin</option>
            </select>

            <button class="btn btn-primary w-100">Đăng ký</button>

            <p class="mt-3 text-center">
                <a href="/TaiKhoan/Login">Quay lại đăng nhập</a>
            </p>
        </form>
    </div>

</body>
</html>