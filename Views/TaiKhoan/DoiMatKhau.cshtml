@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<h1>Đổi mật khẩu</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="DoiMatKhau" method="post" id="doiMatKhauForm">
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label for="newUsername" class="control-label">Tên tài khoản mới</label>
                <input type="text" name="newUsername" id="newUsername" class="form-control" />
                <span id="newUsernameError" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="oldPass" class="control-label">Mật khẩu cũ</label>
                <input type="password" name="oldPass" id="oldPass" class="form-control" />
                <span id="oldPassError" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="newPass" class="control-label">Mật khẩu mới</label>
                <input type="password" name="newPass" id="newPass" class="form-control" />
                <span id="newPassError" class="text-danger"></span>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="text-danger mb-3">@ViewBag.Error</div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="text-success mb-3">@ViewBag.Success</div>
            }

            <div class="form-group">
                <input type="submit" value="Cập nhật" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>